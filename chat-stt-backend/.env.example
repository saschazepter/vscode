# Azure OpenAI resource endpoint, e.g. https://my-resource.openai.azure.com
AZURE_OPENAI_ENDPOINT=

# Azure OpenAI API key (KEY 1 / KEY 2 from the resource's "Keys and Endpoint" page)
AZURE_OPENAI_API_KEY=

# Name of the transcription deployment (a gpt-4o-mini-transcribe or gpt-4o-transcribe deployment)
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini-transcribe

# API version for the audio/transcriptions route
AZURE_OPENAI_API_VERSION=2025-03-01-preview

# Set to "false" to skip GitHub token validation (local testing only)
REQUIRE_GITHUB_AUTH=true

# Max accepted upload size in bytes (Azure's own limit is 25 MB)
MAX_AUDIO_BYTES=26214400
