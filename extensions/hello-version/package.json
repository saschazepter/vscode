{
	"name": "hello-version",
	"displayName": "Hello Version",
	"description": "A Hello World VS Code extension that displays its version.",
	"version": "0.0.1",
	"publisher": "sandy081",
	"engines": {
		"vscode": "^1.114.0"
	},
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "helloVersion.showVersion",
				"title": "Hello Version: Show Version"
			}
		]
	},
	"scripts": {
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"devDependencies": {
		"@types/node": "^20.14.12",
		"@types/vscode": "^1.90.0",
		"typescript": "^5.5.4"
	},
