// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`formatUsageMarkdown > renders a friendly empty-state message when no usage was recorded 1`] = `
"## Copilot usage — last 7 days

No usage data recorded in this window. Usage telemetry begins collecting as you chat with Copilot.
---
_Usage data is collected locally from OpenTelemetry spans and retained for up to 7 days._"
`;

